{
  "name": "@repo/db",
  "version": "1.0.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:migrate": "dotenv -e ../../.env -- drizzle-kit migrate",
    "db:generate": "dotenv -e ../../.env -- drizzle-kit generate",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2"
  }
}
